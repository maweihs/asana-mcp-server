# Required: Asana Personal Access Token
# Get it from: https://app.asana.com/0/my-apps
ASANA_ACCESS_TOKEN=your_asana_token_here

# Required: Secret token to authenticate SSE connections
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
SERVER_ACCESS_TOKEN=your_secret_token_here

# Optional: Port (default: 3000)
# PORT=3000
